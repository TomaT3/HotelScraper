# RapidAPI Key for Booking.com API (https://rapidapi.com/DataCrawler/api/booking-com15)
RAPIDAPI_KEY=your_rapidapi_key_here

# RapidAPI host/base URL for provider endpoint
RAPIDAPI_HOST=booking-com15.p.rapidapi.com
RAPIDAPI_BASE_URL=https://booking-com15.p.rapidapi.com

# API paths (override only if provider changes endpoint names)
RAPIDAPI_LOCATION_ENDPOINT=/api/v1/hotels/locations
RAPIDAPI_HOTELS_ENDPOINT=/api/v1/hotels/search

# App version shown in client status bar
APP_VERSION=1.0.0

# Database path (relative to /app in container, or absolute)
DATABASE_URL=sqlite+aiosqlite:///./data/hotel_prices.db

# Scheduler: how many dates to fetch per run (Free Tier: ~15/day)
DATES_PER_RUN=15

# Scheduler: cron hour to run daily fetch (0-23, default 3 = 3 AM)
FETCH_HOUR=3

# Cities to search (comma-separated, default: Stuttgart)
SEARCH_CITIES=Stuttgart
